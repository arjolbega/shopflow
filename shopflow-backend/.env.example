# Server
PORT=5000
NODE_ENV=production

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=shopflow
DB_USER=shopflow
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD

# JWT
ACCESS_TOKEN_SECRET=CHANGE_THIS_VERY_LONG_RANDOM_STRING
REFRESH_TOKEN_SECRET=CHANGE_THIS_DIFFERENT_VERY_LONG_RANDOM_STRING
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="ShopFlow <your@gmail.com>"

# AWS S3
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_BUCKET_NAME=shopflow-products

# Stripe
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# Redis
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# Frontend
FRONTEND_URL=https://your-domain.com

# Token expiry (minutes)
VERIFICATION_TOKEN_EXPIRY=60
RESET_TOKEN_EXPIRY=30